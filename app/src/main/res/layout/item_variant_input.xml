<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="@dimen/spacing_sm"
    android:background="@color/background_tertiary"
    android:layout_marginBottom="@dimen/spacing_xs"
    android:paddingHorizontal="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/variant_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="@dimen/text_size_sm" />

        <TextView
            android:id="@+id/variant_details"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/btn_remove_variant"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="@dimen/spacing_xs"
        android:src="@drawable/ic_delete"
        android:background="?attr/selectableItemBackgroundBorderless" />

</LinearLayout>
